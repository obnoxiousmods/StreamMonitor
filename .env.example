# StreamMonitor Environment Configuration
# Copy to .env and fill in your values.
# The .env file is loaded automatically at startup (no dotenv dependency).
# API keys can also be configured via the Settings UI at runtime.

# ── Session Secret (auto-generated if not set) ──
# MONITOR_SECRET=

# ── Service Base URLs ──
# Override the default localhost:port for any service.
# COMET_URL=http://127.0.0.1:8070
# MEDIAFUSION_URL=https://127.0.0.1:8090
# STREMTHRU_URL=http://127.0.0.1:8080
# ZILEAN_URL=http://127.0.0.1:8181
# AIOSTREAMS_URL=http://127.0.0.1:7070
# JACKETT_URL=http://127.0.0.1:9117
# PROWLARR_URL=http://127.0.0.1:9696
# FLARESOLVERR_URL=http://127.0.0.1:8191
# BYPARR_URL=http://127.0.0.1:8192
# RADARR_URL=http://127.0.0.1:7878
# SONARR_URL=http://127.0.0.1:8989
# LIDARR_URL=http://127.0.0.1:8686
# BAZARR_URL=http://127.0.0.1:6767
# JELLYFIN_URL=http://127.0.0.1:8096
# PLEX_URL=http://127.0.0.1:32400
# JELLYSEERR_URL=http://127.0.0.1:5055
# DISPATCHARR_URL=http://127.0.0.1:8001
# DISPATCHARR_API_URL=http://127.0.0.1:9191
# MEDIAFLOW_URL=http://127.0.0.1:8060
# QBITTORRENT_URL=http://127.0.0.1:10000

# ── API Keys ──
# Alternatively, put these in ~/.apikeys (key=value format).
JELLYFIN_API_KEY=
JACKETT_API_KEY=
PROWLARR_API_KEY=
RADARR_API_KEY=
SONARR_API_KEY=
LIDARR_API_KEY=
BAZARR_API_KEY=
JELLYSEERR_API_KEY=
ZILEAN_API_KEY=
GITHUB_TOKEN=
PLEX_TOKEN=

# ── Service Credentials ──
DISPATCHARR_USER=admin
DISPATCHARR_PASS=
STREMTHRU_USER=admin
STREMTHRU_PASS=
COMET_ADMIN_PASS=
QBT_USER=admin
QBT_PASS=
MEDIAFUSION_PASS=
MEDIAFUSION_EMAIL=
MEDIAFUSION_USER_PASS=
AIOSTREAMS_SECRET=

# ── Data / File Paths ──
# COMET_CHANGELOG=/path/to/comet/CHANGELOG.md
# STREMTHRU_DB=/path/to/stremthru/data/stremthru.db
# AIOSTREAMS_DB=/path/to/AIOStreams/data/db.sqlite
# JACKETT_INDEXER_DIR=/var/lib/jackett/Indexers
# PLEX_PREFS_PATH=/var/lib/plex/Plex Media Server/Preferences.xml
# PLEX_LOG_DIR=/var/lib/plex/Plex Media Server/Logs

# ── Speed Test ──
# External URLs for the login-page speed test widget.
# Leave empty to disable speed test on the login page.
SPEEDTEST_DIRECT_URL=
SPEEDTEST_DIRECT_NAME=Direct
SPEEDTEST_CF_URL=
SPEEDTEST_CF_NAME=Cloudflare

# ── Benchmark ──
# Base64-encoded Stremio addon config tokens for the benchmark feature.
# These are the URL path segments from your addon install URLs.
# BENCH_COMET_CONFIG=
# BENCH_MEDIAFUSION_CONFIG=
# BENCH_STREMTHRU_CONFIG=
# BENCH_AIOSTREAMS_CONFIG=
# BENCH_TORRENTIO_RD_KEY=
